---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Free Ideal Weight Calculator (2026) – Find Your Perfect Body Weight"
  description="Find your ideal weight using 4 scientific formulas. Compare results and healthy weight ranges instantly."
  keywords="ideal weight calculator, ideal body weight, healthy weight for height, ideal weight for women, ideal weight for men, Devine formula, Robinson formula"
  canonicalUrl="https://calbmi.com/ideal-weight.html"
  bodyClass="brand-ideal"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "CalBmi - Ideal Weight Calculator",
      "url": "https://calbmi.com/ideal-weight.html",
      "description": "Calculate your ideal body weight using 4 scientific formulas.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "offers": { "@type": "Offer", "price": "0.00", "priceCurrency": "USD" },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.7",
        "ratingCount": "198",
        "bestRating": "5",
        "worstRating": "1"
      }
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is ideal body weight and how is it determined?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ideal body weight (IBW) is an estimated weight considered healthiest for a given height. It is determined using medical formulas like Devine, Robinson, Miller, and Hamwi that calculate weight based on height and gender. These formulas were originally developed for drug dosing but are now widely used for general health assessment." }
      }, {
        "@type": "Question",
        "name": "Which ideal weight formula is most accurate?",
        "acceptedAnswer": { "@type": "Answer", "text": "No single formula is definitively most accurate for all individuals. The Devine formula is most commonly used in clinical settings. The Robinson formula tends to give slightly higher values. Using the average of all four formulas provides the most balanced estimate of ideal weight." }
      }, {
        "@type": "Question",
        "name": "Does frame size affect ideal weight?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. People with larger bone structures naturally weigh more at the same height. A small frame may have an ideal weight 10% below the calculated average, while a large frame may be 10% above. You can estimate frame size by wrapping your thumb and finger around your wrist." }
      }, {
        "@type": "Question",
        "name": "What is the ideal weight for 5 feet 8 inches?",
        "acceptedAnswer": { "@type": "Answer", "text": "For a male at 5'8\" (173 cm), the ideal weight ranges from approximately 63–72 kg (139–159 lbs) depending on the formula used. For a female at 5'8\", the range is approximately 59–68 kg (130–150 lbs). Frame size can shift these values by ±10%." }
      }, {
        "@type": "Question",
        "name": "Is ideal weight the same as healthy weight?",
        "acceptedAnswer": { "@type": "Answer", "text": "Not exactly. Ideal weight formulas give a single point estimate, while healthy weight is a range — typically a BMI between 18.5 and 24.9. Someone can be at a healthy weight without being at their calculated 'ideal' weight. Both metrics are useful screening tools." }
      }]
    }
    </script>
  </Fragment>

  <section id="iw-calculator" class="calc-section" style="padding-top:2.5rem">
    <div class="container">
      <div class="calc-page-header scroll-reveal">
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          BMI Calculator
        </a>
        <div class="calc-page-title-block">
          <span class="hero-badge hero-badge-brand" style="margin:0">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            4 Scientific Formulas
          </span>
          <h1 class="calc-page-title">Ideal Weight <span class="hero-gradient-brand">Calculator</span></h1>
        </div>
      </div>

      <div class="calc-grid">
        <!-- Input Card -->
        <div class="card calc-card scroll-reveal" style="--reveal-delay:0.05s">
          <div class="card-header">
            <h2 class="card-title">Enter Your Details</h2>
            <p class="card-subtitle">We'll calculate your ideal weight using 4 formulas</p>
          </div>

          <div class="unit-toggle-group" role="group" aria-label="Unit system">
            <button class="unit-btn active" id="btnMetric" onclick="setUnit('metric')">Metric</button>
            <button class="unit-btn" id="btnImperial" onclick="setUnit('imperial')">Imperial</button>
          </div>

          <form id="iwForm" class="bmi-form" novalidate>
            <!-- Gender -->
            <div class="form-group">
              <label class="form-label">Gender</label>
              <div class="gender-group">
                <label class="gender-option">
                  <input type="radio" name="iwGender" value="male" checked />
                  <span class="gender-card">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.58-7 8-7s8 3 8 7"/></svg>
                    Male
                  </span>
                </label>
                <label class="gender-option">
                  <input type="radio" name="iwGender" value="female" />
                  <span class="gender-card">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.58-7 8-7s8 3 8 7"/><path d="M9 20h6"/></svg>
                    Female
                  </span>
                </label>
              </div>
            </div>

            <!-- Height Metric -->
            <div class="form-group" id="iwHeightMetricGroup">
              <label class="form-label" for="iwHeightCm">Height</label>
              <div class="input-wrapper">
                <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M4 6l3 3M4 12h4M4 18l3-3M20 6l-3 3M20 12h-4M20 18l-3-3"/></svg>
                <input class="form-input" type="number" id="iwHeightCm" placeholder="e.g. 175" min="100" max="280" />
                <span class="input-unit">cm</span>
              </div>
              <div class="form-error" id="iwHeightCmError"></div>
            </div>

            <!-- Height Imperial -->
            <div class="form-group hidden" id="iwHeightImperialGroup">
              <label class="form-label">Height</label>
              <div class="imperial-row">
                <div class="input-wrapper">
                  <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20"/></svg>
                  <input class="form-input" type="number" id="iwHeightFt" placeholder="5" min="1" max="9" />
                  <span class="input-unit">ft</span>
                </div>
                <div class="input-wrapper">
                  <input class="form-input" type="number" id="iwHeightIn" placeholder="9" min="0" max="11" />
