<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TZYFZY1LY9" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-TZYFZY1LY9');
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Internal Server Error (500) | BMICalc</title>
  <meta name="description" content="An internal server error occurred. Return to BMICalc to calculate your BMI and daily calorie needs." />
  <meta name="robots" content="noindex, follow" />
  <link rel="canonical" href="https://calbmi.com/500.html" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://calbmi.com/500.html" />
  <meta property="og:title" content="Internal Server Error (500) | BMICalc" />
  <meta property="og:description" content="An internal server error occurred. Return to BMICalc to calculate your BMI and daily calorie needs." />
  <meta property="og:image" content="https://calbmi.com/social-preview.png" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://calbmi.com/500.html" />
  <meta property="twitter:title" content="Internal Server Error (500) | BMICalc" />
  <meta property="twitter:description" content="An internal server error occurred. Return to BMICalc to calculate your BMI and daily calorie needs." />
  <meta property="twitter:image" content="https://calbmi.com/social-preview.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />

  <!-- Inline Theme Initialization -->
  <script is:inline>
    (function initTheme() {
      const saved = localStorage.getItem('bmiTheme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body style="overflow-y: hidden;">

  <!-- Full Page Main Content (No Header, No Footer) -->
  <main class="error-section">
    <div class="container">
      <div class="scroll-reveal" style="max-width: 680px; margin: 0 auto;">
        <!-- Dribbble GIF Container -->
        <div class="error-gif-box" aria-hidden="true">
          <h1 class="error-code-title" style="background: linear-gradient(135deg, #f97316 0%, #ef4444 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">500</h1>
        </div>

        <!-- Description Box -->
        <div class="error-content-box">
          <h2 class="error-title-text">Oops! Something went wrong</h2>
          <p class="error-desc-text">An internal server error occurred. We are working to fix it!</p>
          <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <button onclick="location.reload()" class="calc-btn" style="margin: 0; display: inline-flex; align-items: center; gap: 0.5rem; background: #16a34a; box-shadow: 0 8px 32px rgba(22, 163, 74, 0.25); border: none;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
              Reload Page
            </button>
            <a href="/" class="reset-btn" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0 1.5rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
              Go to Home
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src="/shared.js" is:inline></script>
</body>
</html>
