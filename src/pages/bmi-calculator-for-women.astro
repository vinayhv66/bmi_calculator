---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="BMI Calculator for Women (2026) – Check Female BMI by Height & Weight"
  description="Calculate BMI for women with our free online calculator. Get accurate female BMI ranges, height-weight reference charts, pregnancy guidelines, and health risks."
  keywords="bmi calculator for women, bmi calculator female, healthy weight for 160 cm female, female bmi chart, ideal weight for women"
  canonicalUrl="https://calbmi.com/bmi-calculator-for-women.html"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "BMICalc - BMI Calculator for Women",
      "url": "https://calbmi.com/bmi-calculator-for-women.html",
      "description": "Calculate Body Mass Index (BMI) specifically for women. Includes customized female ideal weight targets and pregnancy health guidelines.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": { "@type": "Offer", "price": "0.00", "priceCurrency": "USD" }
    }
    </script>
  </Fragment>

  <!-- Calculator Section -->
  <section id="calculator" class="calc-section" style="padding-top:2.5rem">
    <div class="container">
      <div class="bmi-page-header scroll-reveal">
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Home
        </a>
        <div class="bmi-page-title-block">
