          <h1 class="bmi-page-title">BMI Calculator <span class="hero-gradient">for Women</span></h1>
        </div>
        <p class="bmi-page-sub">Analyze your Body Mass Index with female-specific ideal weight & health parameters.</p>
      </div>

      <div class="calc-grid">
        <!-- Input Card -->
        <div class="card calc-card scroll-reveal" style="--reveal-delay:0.05s">
          <div class="card-header">
            <h2 class="card-title">Enter Your Details</h2>
            <p class="card-subtitle">Fill in your measurements below</p>
