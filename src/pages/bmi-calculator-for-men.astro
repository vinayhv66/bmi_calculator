---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="BMI Calculator for Men (2026) – Check Male BMI by Height & Weight"
  description="Calculate BMI specifically for men. Get male weight charts, ideal body weight targets, and health risks."
  keywords="bmi calculator for men, bmi calculator male, bmi 30 male, healthy weight for 170 cm male, male bmi chart, ideal weight for men"
  canonicalUrl="https://calbmi.com/bmi-calculator-for-men.html"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "CalBmi - BMI Calculator for Men",
      "url": "https://calbmi.com/bmi-calculator-for-men.html",
      "description": "Calculate Body Mass Index (BMI) and ideal weight specifically for men.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": { "@type": "Offer", "price": "0.00", "priceCurrency": "USD" },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "148",
        "bestRating": "5",
        "worstRating": "1"
      }
    }
    </script>
  </Fragment>

  <!-- Calculator Section -->
  <section id="calculator" class="calc-section" style="padding-top:2.5rem">
    <div class="container">
      <div class="bmi-page-header scroll-reveal">
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Home
        </a>
        <div class="bmi-page-title-block">
          <span class="hero-badge" style="margin:0">
            ♂️ Male Specific
          </span>
          <h1 class="bmi-page-title">BMI Calculator <span class="hero-gradient">for Men</span></h1>
        </div>
        <p class="bmi-page-sub">Analyze your Body Mass Index with male-specific ideal weight & health parameters.</p>
      </div>

      <div class="calc-grid">
        <!-- Input Card -->
