          <thead>
            <tr>
              <th>Height</th>
              <th>Healthy Weight Range (Metric)</th>
              <th>Healthy Weight Range (Imperial)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>165 cm (5'5")</td>
              <td>50.4 – 67.8 kg</td>
              <td>111 – 149 lbs</td>
            </tr>
            <tr>
              <td>170 cm (5'7")</td>
              <td>53.5 – 72.0 kg</td>
              <td>118 – 159 lbs</td>
            </tr>
            <tr>
              <td>175 cm (5'9")</td>
              <td>56.7 – 76.3 kg</td>
              <td>125 – 168 lbs</td>
            </tr>
            <tr>
              <td>180 cm (5'11")</td>
              <td>59.9 – 80.7 kg</td>
              <td>132 – 178 lbs</td>
            </tr>
            <tr>
