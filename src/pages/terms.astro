---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms & Conditions - Health Disclaimer | BMICalc"
  description="Read our terms and conditions. Learn about terms of service, informational use rules, and general health metrics disclaimers."
  keywords="terms and conditions, terms of service, health disclaimer, calculator rules, medical disclaimer"
  canonicalUrl="https://calbmi.com/terms.html"
>
  <!-- Main Content -->
  <main class="container" style="padding-top: 3.5rem; padding-bottom: 5rem;">
    <div class="section-header scroll-reveal">
      <div class="section-badge">Terms of Service</div>
      <h1 class="section-title-lg">Terms &amp; Conditions</h1>
      <p class="section-description" style="max-width: 650px; margin: 0.5rem auto 0;">
        Review the terms of service and healthcare disclaimers that guide the usage of the tools on BMICalc.
      </p>
    </div>

    <!-- Article layout -->
    <div class="card scroll-reveal" style="padding: 2.5rem; max-width: 820px; margin: 2rem auto 0;">
      <div class="seo-article-main" style="margin: 0;">
        <h2>1. Informational Purposes Only</h2>
        <p>All calculators, text charts, tips, and macronutrient breakdowns provided on BMICalc are designed for general informational and screening purposes only. They do not constitute formal medical diagnosis, nutritional advice, or treatment plans. You should always consult with a registered physician or registered dietitian before starting a new diet or strenuous fitness program.</p>
        
        <h2>2. Permitted Use</h2>
        <p>Users are free to use these tools for individual, non-commercial purposes. Scraping, botting, reproducing the formulas, or embedding the calculators in another website without attribution is prohibited.</p>
        
        <h2>3. Disclaimer of Liability</h2>
        <p>BMICalc is provided "as is" without warranties of any kind. We make reasonable efforts to maintain the scientific formulas correctly, but we are not liable for any health decisions or outcomes based on measurements calculated using this website.</p>
      </div>
    </div>
  </main>
</Layout>
