---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us - Get In Touch | BMICalc"
  description="Have questions, suggestions, or feedback about BMICalc? Contact us today using our simple web form and our team will get back to you."
  keywords="contact us, support, feedback, health tools help, get in touch"
  canonicalUrl="https://calbmi.com/contact.html"
>
  <!-- Main Content -->
  <main class="container" style="padding-top: 3.5rem; padding-bottom: 5rem;">
    <div class="section-header scroll-reveal">
      <div class="section-badge">Contact Us</div>
      <h1 class="section-title-lg">Get In Touch</h1>
      <p class="section-description" style="max-width: 650px; margin: 0.5rem auto 0;">
        Have any questions, feedback, or suggestions? Fill out the form below and we will get back to you shortly.
      </p>
    </div>

    <!-- Contact Form Card -->
    <div class="card scroll-reveal" style="padding: 2.5rem; max-width: 600px; margin: 2rem auto 0;" id="contactCard">
      <div id="contactFormWrapper">
        <form id="contactForm" class="bmi-form" novalidate>
          <!-- Name -->
          <div class="form-group">
            <label class="form-label" for="contactName">Name</label>
            <div class="input-wrapper">
              <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <input class="form-input" type="text" id="contactName" placeholder="Your Name" required />
            </div>
            <div class="form-error" id="nameError"></div>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label class="form-label" for="contactEmail">Email Address</label>
            <div class="input-wrapper">
              <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <input class="form-input" type="email" id="contactEmail" placeholder="your.email@example.com" required />
            </div>
            <div class="form-error" id="emailError"></div>
          </div>

          <!-- Message -->
          <div class="form-group">
            <label class="form-label" for="contactMessage">Message</label>
            <div class="input-wrapper">
              <textarea class="form-input" id="contactMessage" rows="5" placeholder="How can we help you?" style="resize: vertical; padding: 0.75rem 1rem; min-height: 120px;" required></textarea>
            </div>
            <div class="form-error" id="messageError"></div>
          </div>

          <button type="submit" class="calc-btn" style="margin-top: 1rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Send Message
          </button>
        </form>
      </div>

      <!-- Success State -->
      <div id="successWrapper" class="hidden" style="text-align: center; padding: 1.5rem 0;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">✉️</div>
        <h2 style="font-size: 1.5rem; font-weight: 800; color: var(--foreground); margin-bottom: 0.5rem;">Message Sent!</h2>
        <p style="color: var(--muted-foreground); margin-bottom: 1.5rem;">Thank you for contacting us. We have received your message and will respond within 24 to 48 hours.</p>
        <button onclick="resetContactForm()" class="reset-btn" style="margin: 0 auto; padding: 0.5rem 1.5rem;">Send Another Message</button>
      </div>
    </div>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('contactForm');
      const formWrapper = document.getElementById('contactFormWrapper');
      const successWrapper = document.getElementById('successWrapper');

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Reset errors
        document.querySelectorAll('.form-error').forEach(el => el.textContent = '');
        document.querySelectorAll('.form-input').forEach(el => el.classList.remove('error'));

        let valid = true;
        const name = document.getElementById('contactName').value.trim();
        const email = document.getElementById('contactEmail').value.trim();
        const message = document.getElementById('contactMessage').value.trim();

        if (!name) {
          document.getElementById('contactName').classList.add('error');
          document.getElementById('nameError').textContent = 'Please enter your name.';
          valid = false;
        }

        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          document.getElementById('contactEmail').classList.add('error');
          document.getElementById('emailError').textContent = 'Please enter a valid email address.';
          valid = false;
        }

        if (!message || message.length < 10) {
          document.getElementById('contactMessage').classList.add('error');
          document.getElementById('messageError').textContent = 'Message must be at least 10 characters long.';
          valid = false;
        }

        if (valid) {
          // Simulate form submission
          formWrapper.classList.add('hidden');
          successWrapper.classList.remove('hidden');
        }
      });
    });

    function resetContactForm() {
      document.getElementById('contactForm').reset();
      document.getElementById('contactFormWrapper').classList.remove('hidden');
      document.getElementById('successWrapper').classList.add('hidden');
    }
  </script>
</Layout>
