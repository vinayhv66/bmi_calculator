---
interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalUrl?: string;
  showFooter?: boolean;
  bodyClass?: string;
}

const { title, description, keywords, canonicalUrl, showFooter = true, bodyClass } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7315536876472042" crossorigin="anonymous"></script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TZYFZY1LY9" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-TZYFZY1LY9');
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="robots" content="index, follow" />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://calbmi.com/social-preview.png" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  {canonicalUrl && <meta property="twitter:url" content={canonicalUrl} />}
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content="https://calbmi.com/social-preview.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css?v=1.0.2" />

  <!-- Inline Theme Initialization -->
  <script is:inline>
    (function initTheme() {
      const saved = localStorage.getItem('bmiTheme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>

  <slot name="head" />
</head>
<body class={bodyClass}>
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <div class="logo">
        <a href="/" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: inherit;">
          <img src="/favicon.png" width="32" height="32" alt="CalBmi Logo" style="border-radius: 8px;" />
          <span class="logo-text">Cal<span class="logo-accent">Bmi</span></span>
        </a>
      </div>
      <nav class="header-nav">
        <!-- BMI Dropdown -->
        <div class="nav-dropdown" id="bmiDropdown">
          <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            BMI Calculator
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="nav-dropdown-menu">
            <a href="/" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(99,102,241,0.1);color:#6366f1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">General BMI Calculator</span>
                <span class="nav-dropdown-item-desc">Standard BMI assessment for adults</span>
              </span>
            </a>
            <a href="/bmi-calculator-for-men.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(59,130,246,0.1);color:#3b82f6">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="14" r="5"/><path d="M19 5l-5.4 5.4M14 5h5v5"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">BMI for Men</span>
                <span class="nav-dropdown-item-desc">Male-specific analysis & charts</span>
              </span>
            </a>
            <a href="/bmi-calculator-for-women.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(236,72,153,0.1);color:#ec4899">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M12 13v8M9 16h6"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">BMI for Women</span>
                <span class="nav-dropdown-item-desc">Female-specific analysis & charts</span>
              </span>
            </a>
            <a href="/bmi-calculator-for-children.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(16,185,129,0.1);color:#10b981">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">BMI for Children</span>
                <span class="nav-dropdown-item-desc">Percentiles for kids & teens (2-19)</span>
              </span>
            </a>
            <a href="/bmi-calculator-by-age.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(139,92,246,0.1);color:#8b5cf6">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">BMI by Age</span>
                <span class="nav-dropdown-item-desc">Age-adjusted classifications</span>
              </span>
            </a>
            <a href="/bmi-calculator-india.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(245,158,11,0.1);color:#f59e0b">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">BMI Calculator India</span>
                <span class="nav-dropdown-item-desc">Modified ranges for South Asians</span>
              </span>
            </a>
            <a href="/bmi-calculator-kg-cm.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(14,165,233,0.1);color:#0ea5e9">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">BMI in kg & cm</span>
                <span class="nav-dropdown-item-desc">Metric height & weight inputs</span>
              </span>
            </a>
          </div>
        </div>

        <!-- Calculators Dropdown -->
        <div class="nav-dropdown" id="calcDropdown">
          <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            Calculators
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="nav-dropdown-menu">
            <a href="/calories.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(249,115,22,0.1);color:#f97316">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">Calorie Calculator</span>
                <span class="nav-dropdown-item-desc">Daily caloric needs & macros</span>
              </span>
            </a>
            <a href="/tdee.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(16,185,129,0.1);color:#10b981">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">TDEE Calculator</span>
                <span class="nav-dropdown-item-desc">Total daily energy expenditure</span>
              </span>
            </a>
            <a href="/ideal-weight.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(14,165,233,0.1);color:#0ea5e9">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 21h18M12 7H4.5a2.5 2.5 0 0 0 0 5H12M12 7h7.5a2.5 2.5 0 0 1 0 5H12"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">Ideal Weight Calculator</span>
                <span class="nav-dropdown-item-desc">Find your perfect body weight</span>
              </span>
            </a>
            <a href="/body-fat.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(244,63,94,0.1);color:#f43f5e">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="10" rx="1"/><line x1="6" y1="7" x2="6" y2="12"/><line x1="10" y1="7" x2="10" y2="10"/><line x1="14" y1="7" x2="14" y2="12"/><line x1="18" y1="7" x2="18" y2="10"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">Body Fat Calculator</span>
                <span class="nav-dropdown-item-desc">Estimate body fat percentage</span>
              </span>
            </a>
            <a href="/bmr.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(245,158,11,0.1);color:#f59e0b">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">BMR Calculator</span>
                <span class="nav-dropdown-item-desc">Basal metabolic rate</span>
              </span>
            </a>
            <a href="/lean-body-mass.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(20,184,166,0.1);color:#14b8a6">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h2a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2M6 8H4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2M6 12h12M6 7h2v10H6zm10 0h2v10h-2z"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">Lean Body Mass Calculator</span>
                <span class="nav-dropdown-item-desc">Fat-free mass estimation</span>
              </span>
            </a>
            <a href="/macro.html" class="nav-dropdown-item">
              <span class="nav-dropdown-icon" style="background:rgba(139,92,246,0.1);color:#8b5cf6">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
              </span>
              <span class="nav-dropdown-item-text">
                <span class="nav-dropdown-item-name">Macro Calculator</span>
                <span class="nav-dropdown-item-desc">Protein, carbs & fat split</span>
              </span>
            </a>
          </div>
        </div>

        <a href="/#chart" class="nav-link">BMI Chart</a>
        <a href="/#faq" class="nav-link">FAQ</a>
      </nav>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
        <svg id="sunIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="moonIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle navigation menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line class="line-top" x1="4" y1="6" x2="20" y2="6"/>
          <line class="line-mid" x1="4" y1="12" x2="20" y2="12"/>
          <line class="line-bot" x1="4" y1="18" x2="20" y2="18"/>
        </svg>
      </button>
    </div>
  </header>

  <slot />

  <!-- Footer -->
  {showFooter && (
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand Column -->
        <div class="footer-brand">
          <div class="logo">
            <img src="/favicon.png" width="24" height="24" alt="CalBmi Logo" style="border-radius: 6px;" />
            <span class="logo-text">Cal<span class="logo-accent">Bmi</span></span>
          </div>
          <p class="footer-brand-desc">Free, accurate health calculators based on WHO & CDC standards. Calculate BMI, TDEE, body fat, and more.</p>
        </div>

        <!-- Calculators Column -->
        <div>
          <h4 class="footer-col-title">Calculators</h4>
          <div class="footer-col-links">
            <a href="/" class="footer-link">BMI Calculator</a>
            <a href="/calories.html" class="footer-link">Calorie Calculator</a>
            <a href="/tdee.html" class="footer-link">TDEE Calculator</a>
            <a href="/ideal-weight.html" class="footer-link">Ideal Weight</a>
            <a href="/body-fat.html" class="footer-link">Body Fat Calculator</a>
            <a href="/bmr.html" class="footer-link">BMR Calculator</a>
            <a href="/lean-body-mass.html" class="footer-link">Lean Body Mass</a>
            <a href="/macro.html" class="footer-link">Macro Calculator</a>
          </div>
        </div>

        <!-- Resources Column -->
        <div>
          <h4 class="footer-col-title">Resources</h4>
          <div class="footer-col-links">
            <a href="/bmi-calculator-for-men.html" class="footer-link">BMI for Men</a>
            <a href="/bmi-calculator-for-women.html" class="footer-link">BMI for Women</a>
            <a href="/bmi-calculator-for-children.html" class="footer-link">BMI for Children</a>
            <a href="/bmi-calculator-india.html" class="footer-link">BMI Calculator India</a>
            <a href="/bmi-calculator-by-age.html" class="footer-link">BMI by Age</a>
            <a href="/bmi-calculator-kg-cm.html" class="footer-link">BMI in kg & cm</a>
          </div>
        </div>

        <!-- Company Column -->
        <div>
          <h4 class="footer-col-title">Company</h4>
          <div class="footer-col-links">
            <a href="/about.html" class="footer-link">About Us</a>
            <a href="/contact.html" class="footer-link">Contact</a>
            <a href="/privacy.html" class="footer-link">Privacy Policy</a>
            <a href="/terms.html" class="footer-link">Terms & Conditions</a>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-disclaimer">This calculator is for informational purposes only. Always consult a healthcare professional for medical advice.</p>
        <p class="footer-copy">&copy; 2026 CalBmi. Built with care for your health.</p>
      </div>
    </div>
  </footer>
  )}

  <script src="/shared.js?v=1.0.2" is:inline></script>
</body>
</html>
